# devel-base 環境変数テンプレート
# 利用手順:
#   cp .env.example .env
#   各値を埋める（本番では SSM Parameter Store / Secrets Manager から取得）

# ---- ドメイン / TLS ----
# 本番: devel-base.example.com
# ローカル: localhost  （*.localhost は自動でループバックに解決）
DOMAIN_BASE=localhost
# Let's Encrypt 通知メール（本番では実アドレス、ローカルは何でもよい）
LE_EMAIL=admin@example.com

# ---- 共有 PostgreSQL ----
# スーパーユーザ。アプリからは使わず、メンテ・バックアップ用途のみ。
POSTGRES_USER=postgres
POSTGRES_PASSWORD=

# Redmine 用 DB・ユーザ（postgres コンテナの初期化スクリプトで作成）
REDMINE_DB_NAME=redmine
REDMINE_DB_USER=redmine
REDMINE_DB_PASSWORD=
# Rails の session / cookie 用秘密鍵（`openssl rand -hex 64` で生成）
REDMINE_SECRET_KEY_BASE=

# SonarQube 用 DB・ユーザ
SONARQUBE_DB_NAME=sonarqube
SONARQUBE_DB_USER=sonarqube
SONARQUBE_DB_PASSWORD=
